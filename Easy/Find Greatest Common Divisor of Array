class Solution {
    public int findGCD(int[] nums) {
        Arrays.sort(nums);
        int a,b;
        a=nums[0];
        b=nums[nums.length-1];
        return gcd(a,b);}
       public int gcd(int a,int b){
            if(b==0){
            return a;
        }
        else{
            return gcd(b,a%b);
        }
        
    }
}