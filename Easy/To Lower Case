class Solution {
    public String toLowerCase(String s) {
        String result="";
        for(int i=0;i<s.length();i++){
            char ch=s.charAt(i);
            if(ch>=65 && ch<=90){
                char chs=(char)(ch+32);
                result=result+chs;

            }
            else{
                result=result+ch;
            }
        }
        return result;
    }
}